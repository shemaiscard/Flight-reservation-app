import sqlite3

def create_tables():
    with sqlite3.connect("flight_reservation.db") as conn:
        cursor = conn.cursor()
        
        cursor.execute("""
        CREATE TABLE IF NOT EXISTS Flight (
            FlightID INTEGER PRIMARY KEY AUTOINCREMENT,
            FlightNumber TEXT UNIQUE NOT NULL,
            DepartureDateTime TEXT NOT NULL,
            ArrivalDateTime TEXT NOT NULL,
            OriginAirportCode TEXT NOT NULL,
            DestinationAirportCode TEXT NOT NULL,
            AvailableSeats INTEGER NOT NULL,
            AirlineID INTEGER NOT NULL,
            FOREIGN KEY (OriginAirportCode) REFERENCES Airport(AirportCode),
            FOREIGN KEY (DestinationAirportCode) REFERENCES Airport(AirportCode),
            FOREIGN KEY (AirlineID) REFERENCES Airline(AirlineID)
        )
        """)
        
        cursor.execute("""
        CREATE TABLE IF NOT EXISTS Passenger (
            PassengerID INTEGER PRIMARY KEY AUTOINCREMENT,
            FirstName TEXT NOT NULL,
            LastName TEXT NOT NULL,
            Email TEXT NOT NULL,
            PassportNumber TEXT NOT NULL
        )
        """)
        
        cursor.execute("""
        CREATE TABLE IF NOT EXISTS Airport (
            AirportCode TEXT PRIMARY KEY,
            AirportName TEXT NOT NULL,
            Location TEXT NOT NULL,
            Facilities TEXT
        )
        """)
        
        cursor.execute("""
        CREATE TABLE IF NOT EXISTS Airline (
            AirlineID INTEGER PRIMARY KEY AUTOINCREMENT,
            AirlineName TEXT NOT NULL,
            ContactNumber TEXT NOT NULL,
            OperatingRegion TEXT NOT NULL
        )
        """)
        
        cursor.execute("""
        CREATE TABLE IF NOT EXISTS Booking (
            BookingID INTEGER PRIMARY KEY AUTOINCREMENT,
            FlightID INTEGER NOT NULL,
            PassengerID INTEGER NOT NULL,
            PaymentStatus TEXT NOT NULL,
            FOREIGN KEY (FlightID) REFERENCES Flight(FlightID),
            FOREIGN KEY (PassengerID) REFERENCES Passenger(PassengerID)
        )
        """)
        
        cursor.execute("""
        CREATE TABLE IF NOT EXISTS Payment (
            PaymentID INTEGER PRIMARY KEY AUTOINCREMENT,
            BookingID INTEGER NOT NULL UNIQUE,
            PaymentMethod TEXT NOT NULL,
            Amount REAL NOT NULL,
            TransactionDateTime TEXT NOT NULL,
            FOREIGN KEY (BookingID) REFERENCES Booking(BookingID)
        )
        """)


if __name__ == "__main__":
    create_tables() 
    

import sqlite3

def insert_data():
    with sqlite3.connect("flight_reservation.db") as conn:
        cursor = conn.cursor()
        
        # Clear existing data from the Airport table
        cursor.execute("DELETE FROM Airport")
        cursor.execute("DELETE FROM Flight")
        cursor.execute("DELETE FROM Booking")
        cursor.execute("DELETE FROM Airline")
        cursor.execute("DELETE FROM Payment")
        cursor.execute("DELETE FROM Passenger")


        # Insert data into the Airport table
        cursor.executemany("INSERT INTO Airport (AirportCode, AirportName, Location, Facilities) VALUES (?, ?, ?, ?)", [
            ("JFK", "John F. Kennedy International Airport", "New York", "WiFi, Restaurants"),
            ("LAX", "Los Angeles International Airport", "Los Angeles", "Shopping, Lounges"),
            ("ORD", "O'Hare International Airport", "Chicago", "Parking, Duty-Free Shops"),
            ("DXB", "Dubai International Airport", "Dubai", "Shopping, Lounges"),
            ("FRA", "Frankfurt Airport", "Frankfurt", "Restaurants, Lounges")
            # Add more airports here
        ])
        
        # Insert data into the Airline table
        cursor.executemany("INSERT INTO Airline (AirlineName, ContactNumber, OperatingRegion) VALUES (?, ?, ?)", [
            ("Delta Air Lines", "123-456-7890", "North America"),
            ("American Airlines", "987-654-3210", "North America"),
            ("United Airlines", "456-789-0123", "North America"),
            ("Emirates", "971-4-123-4567", "Middle East"),
            ("Lufthansa", "49-69-123-4567", "Europe")
            # Add more airlines here
        ])
        
        # Insert data into the Flight table
        cursor.executemany("INSERT INTO Flight (FlightNumber, DepartureDateTime, ArrivalDateTime, OriginAirportCode, DestinationAirportCode, AvailableSeats, AirlineID) VALUES (?, ?, ?, ?, ?, ?, ?)", [
            ("DL100", "2024-06-01 08:00:00", "2024-06-01 10:30:00", "JFK", "LAX", 150, 1),
            ("AA200", "2024-06-02 10:00:00", "2024-06-02 13:30:00", "LAX", "ORD", 200, 2),
            ("UA300", "2024-06-03 12:00:00", "2024-06-03 15:30:00", "ORD", "JFK", 180, 3),
            ("EK400", "2024-06-04 14:00:00", "2024-06-04 18:30:00", "JFK", "DXB", 220, 4),
            ("LH500", "2024-06-05 16:00:00", "2024-06-05 20:30:00", "ORD", "FRA", 190, 5)
            
        ])


        # Insert data into the Booking table
        cursor.executemany("INSERT INTO Booking (FlightID, PassengerID, PaymentStatus) VALUES (?, ?, ?)", [
            (1, 1, "Paid"),
            (2, 2, "Pending"),
            (3, 3, "Paid")
            # Add more bookings here
        ])

        # Insert data into the Payment table
        cursor.executemany("INSERT INTO Payment (BookingID, PaymentMethod, Amount, TransactionDateTime) VALUES (?, ?, ?, ?)", [
            (1, "Credit Card", 250.00, "2024-06-01 07:45:00"),
            (3, "PayPal", 300.00, "2024-06-03 11:30:00")
            # Add more payments here
        ])

if __name__ == "__main__":
    insert_data()
    pass
import sqlite3

# Connect to the database
conn = sqlite3.connect('FlightReservation.db')
c = conn.cursor()

# Create tables for users and admins
c.execute('''
CREATE TABLE IF NOT EXISTS users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT NOT NULL,
    password TEXT NOT NULL
)
''')

c.execute('''
CREATE TABLE IF NOT EXISTS admins (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT NOT NULL,
    password TEXT NOT NULL
)
''')

# Insert sample data into users table
c.execute("INSERT INTO users (username, password) VALUES ('user1', 'password1')")
c.execute("INSERT INTO users (username, password) VALUES ('user2', 'password2')")

# Insert sample data into admins table
c.execute("INSERT INTO admins (username, password) VALUES ('admin1', 'password1')")
c.execute("INSERT INTO admins (username, password) VALUES ('admin2', 'password2')")

# Commit the changes and close the connection
conn.commit()
conn.close()
pass
